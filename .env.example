# Copy to .env on server and fill real values before live marketplace writes.
WEBHOOK_URL=https://hooks.example.com/webhook/
FACTORY_CONNECTORS_MODE=mock
FACTORY_WEBHOOK_ALLOW_UNSIGNED=false

# Customer Connect Center public links. Leave blank rather than pointing to fake accounts.
LINE_OA_URL=
_LINEBot_BASIC_ID=
TELEGRAM_BOT_URL=
TELEGRAM_BOT_USERNAME=
INSTAGRAM_DM_URL=https://www.instagram.com/successcasting/
CUSTOMER_SUPPORT_EMAIL=hello@successcasting.com

# Optional AI Sales Concierge LLM. Set real key only on server, never in git.
AI_SALES_GEMINI_API_KEY=
GEMINI_API_KEY=
GEMINI_API=
GEMINI_KEY=
GOOGLE_API_KEY=
AI_SALES_GEMINI_MODEL=gemini-2.5-flash-lite
AI_SALES_OPENAI_API_KEY=
AI_SALES_OPENAI_URL=
AI_SALES_OPENAI_MODEL=

# Optional Cloudflare AI Gateway in front of Gemini/OpenAI-compatible providers.
CLOUDFLARE_API_TOKEN=
Cloudfaire_API=
Cloudfaire_API_TOKEN=
AI_SALES_CLOUDFLARE_AI_GATEWAY_URL=
CLOUDFLARE_AI_GATEWAY_URL=
CF_AI_GATEWAY_URL=

# Optional transactional email; when absent, email confirmations are recorded as not_configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=hello@successcasting.com

SHOPEE_APP_SECRET=
LAZADA_APP_SECRET=
TIKTOK_APP_SECRET=

# Optional future live connector credentials.
SHOPEE_PARTNER_ID=
SHOPEE_SHOP_ID=
SHOPEE_REFRESH_TOKEN=
LAZADA_APP_KEY=
LAZADA_SELLER_ID=
LAZADA_REFRESH_TOKEN=
TIKTOK_APP_KEY=
TIKTOK_SHOP_ID=
TIKTOK_REFRESH_TOKEN=
FB_ACCESS_TOKEN=
# Admin dashboard staff login (set real secrets in .env, do not commit)
ADMIN_DASHBOARD_USER=salesadmin
ADMIN_DASHBOARD_PASSWORD=change-me-in-production
ADMIN_DASHBOARD_ROLE=admin
ADMIN_PASSWORD_SALT=change-me-random-salt
SALES_NOTIFY_EMAIL=

# LINE OA / sales group push notification (real LINE Messaging API)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QuoteStatus {
  DRAFT
  SUBMITTED
  AI_ESTIMATED
  CUSTOMER_APPROVED
  IN_PRODUCTION
  SHIPPED
  CANCELLED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  CANCELLED
}

enum AIRequestType {
  SMART_SEARCH
  QUOTE_GENERATOR
  DEFECT_ANALYZER
  PRODUCTION_ADVISOR
  AI_SEO_BLOG
  AI_SEO_FAQ
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum MediaApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Users {
  id            String          @id @default(uuid()) @db.Uuid
  clerkUserId   String          @unique
  email         String?
  fullName      String?
  role          UserRole        @default(CUSTOMER)
  companyId     String?         @db.Uuid
  company       Companies?      @relation(fields: [companyId], references: [id])
  quotes        Quotes[]
  orders        Orders[]
  aiRequests    AI_Requests[]
  uploadedFiles Uploaded_Files[]
  costAuditLogs CostAuditLogs[]
  approvedMedia MediaAssets[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([clerkUserId])
  @@map("Users")
}

model Companies {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  website   String?
  country   String?
  city       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     Users[]
  products  Products[]
  quotes    Quotes[]
  orders    Orders[]

  @@index([slug])
  @@map("Companies")
}

model Categories {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Products[]

  @@index([slug])
  @@map("Categories")
}

model Products {
  id           String      @id @default(uuid()) @db.Uuid
  companyId    String      @db.Uuid
  categoryId   String      @db.Uuid
  sku          String?
  name         String
  slug         String      @unique
  description  String?
  // A compact field used for fast "LIKE"/keyword matching before we upgrade to vector search.
  searchText   String      @db.Text
  specs        Json?
  seoTitle      String?
  seoDescription String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Companies   @relation(fields: [companyId], references: [id])
  category     Categories  @relation(fields: [categoryId], references: [id])
  quotes       Quotes[]
  inventory    Inventory[]

  @@index([categoryId])
  @@index([companyId])
  @@index([name])
  @@map("Products")
}

model Quotes {
  id                 String        @id @default(uuid()) @db.Uuid
  companyId          String        @db.Uuid
  userId             String?       @db.Uuid
  productId          String?       @db.Uuid
  materialId         String?       @db.Uuid
  status             QuoteStatus  @default(DRAFT)
  inputWeightKg      Float?
  complexityScore    Float?
  machiningHours     Float?
  formulaVersionId   String?       @db.Uuid
  overheadRate       Float?
  marginRate         Float?
  leadTimeDays       Int?
  estimatedPriceUsd  Float?
  materialCostUsd    Float?
  castingCostUsd     Float?
  machiningCostUsd   Float?
  laborCostUsd       Float?
  overheadCostUsd    Float?
  marginCostUsd      Float?
  quoteSummary       String?
  aiExplanation      String?
  specsInput         String?
  aiOutputJson       Json?
  approvedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  company            Companies     @relation(fields: [companyId], references: [id])
  user               Users?        @relation(fields: [userId], references: [id])
  product            Products?     @relation(fields: [productId], references: [id])
  material           Materials?    @relation(fields: [materialId], references: [id])
  formulaVersion     CostFormulaVersions? @relation(fields: [formulaVersionId], references: [id])
  orders             Orders[]
  aiRequests         AI_Requests[]
  uploadedFiles      Uploaded_Files[]

  @@index([companyId])
  @@index([userId])
  @@index([productId])
  @@index([materialId])
  @@index([formulaVersionId])
  @@index([status])
  @@map("Quotes")
}

model Materials {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  pricePerKg  Float
  density     Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  quotes      Quotes[]

  @@index([name])
  @@map("Materials")
}

model ProcessCosts {
  id          String    @id @default(uuid()) @db.Uuid
  type        String    @unique
  costPerHour Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@map("ProcessCosts")
}

model CostFormulaVersions {
  id                        String    @id @default(uuid()) @db.Uuid
  versionName               String    @unique
  isActive                  Boolean   @default(false)
  effectiveFrom             DateTime  @default(now())
  effectiveTo               DateTime?
  overheadRate              Float
  marginRate                Float
  laborRatePerHour          Float
  castingHoursBase          Float
  castingHoursPerKg         Float
  castingComplexityFactor   Float
  laborHoursBase            Float
  laborHoursPerKg           Float
  laborComplexityFactor     Float
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  quotes                    Quotes[]
  auditLogs                 CostAuditLogs[]

  @@index([isActive])
  @@map("CostFormulaVersions")
}

model CostAuditLogs {
  id              String    @id @default(uuid()) @db.Uuid
  actorUserId     String?   @db.Uuid
  action          String
  entityType      String
  entityId        String
  formulaVersionId String?  @db.Uuid
  beforeJson      Json?
  afterJson       Json?
  createdAt       DateTime  @default(now())

  actorUser       Users?    @relation(fields: [actorUserId], references: [id])
  formulaVersion  CostFormulaVersions? @relation(fields: [formulaVersionId], references: [id])

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([formulaVersionId])
  @@index([createdAt])
  @@map("CostAuditLogs")
}

model Orders {
  id              String       @id @default(uuid()) @db.Uuid
  companyId       String       @db.Uuid
  quoteId         String       @db.Uuid
  userId          String?      @db.Uuid
  status          OrderStatus @default(CREATED)
  orderNumber    String?
  totalPriceUsd   Float?
  promisedDeliveryAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company         Companies    @relation(fields: [companyId], references: [id])
  quote           Quotes       @relation(fields: [quoteId], references: [id])
  user            Users?       @relation(fields: [userId], references: [id])

  aiRequests      AI_Requests[]

  @@index([companyId])
  @@index([quoteId])
  @@index([status])
  @@map("Orders")
}

model Inventory {
  id               String    @id @default(uuid()) @db.Uuid
  productId        String    @db.Uuid
  location         String
  quantityOnHand   Int
  reservedQuantity Int      @default(0)
  updatedAt        DateTime @updatedAt

  product          Products  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([location])
  @@map("Inventory")
}

model AI_Requests {
  id           String         @id @default(uuid()) @db.Uuid
  type         AIRequestType
  userId       String?        @db.Uuid
  quoteId      String?        @db.Uuid
  orderId      String?        @db.Uuid
  inputText    String?
  outputJson   Json?
  outputText   String?
  model        String?
  createdAt    DateTime       @default(now())

  user          Users?         @relation(fields: [userId], references: [id])
  quote         Quotes?        @relation(fields: [quoteId], references: [id])
  order         Orders?        @relation(fields: [orderId], references: [id])
  uploadedFiles Uploaded_Files[]

  @@index([type])
  @@index([userId])
  @@index([quoteId])
  @@index([orderId])
  @@map("AI_Requests")
}

model Uploaded_Files {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  quoteId      String?  @db.Uuid
  aiRequestId  String?  @db.Uuid

  bucket       String
  storagePath  String
  originalName String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())

  user         Users?        @relation(fields: [userId], references: [id])
  quote        Quotes?       @relation(fields: [quoteId], references: [id])
  aiRequest    AI_Requests?  @relation(fields: [aiRequestId], references: [id])

  @@index([userId])
  @@index([quoteId])
  @@index([aiRequestId])
  @@map("Uploaded_Files")
}

model MediaAssets {
  id            String   @id @default(uuid()) @db.Uuid
  sourceType    String
  mediaType     String
  title         String
  description   String?
  mediaUrl      String
  thumbnailUrl  String?
  sourcePageUrl String   @unique
  sourceName    String?
  license       String?
  author        String?
  tags          Json?
  hotScore      Float    @default(0)
  approvalStatus MediaApprovalStatus @default(PENDING)
  approvedAt    DateTime?
  approvedByUserId String? @db.Uuid
  rejectReason  String?
  viewCount     Int      @default(0)
  manualBoost   Float    @default(0)
  publishedAt   DateTime?
  importedAt    DateTime @default(now())
  isActive      Boolean  @default(true)

  approvedBy    Users?   @relation(fields: [approvedByUserId], references: [id])

  @@index([sourceType])
  @@index([mediaType])
  @@index([approvalStatus])
  @@index([hotScore])
  @@index([importedAt])
  @@map("MediaAssets")
}


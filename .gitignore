# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
tsconfig.tsbuildinfo
*.tsbuildinfo

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env.example is committed (contains placeholder values)
.env.example
# .env.local and .env.*.local are NEVER committed (contain secrets)
.env.local
.env.*.local

# vercel
.vercel

# clerk configuration (can include secrets)
/.clerk/

# pre-existing local files moved aside during repo cleanup (may contain secrets)
/_preexisting_backup/
